# Telegram Bot Token
# Get this from @BotFather on Telegram
BOT_TOKEN=value

# Admin user ID 
ADMIN_ID=value

# Private group invite link
GROUP_INVITE_LINK=https://t.me/value

# Database configuration
# For production, use PostgreSQL: postgresql://user:password@localhost:5432/ask_bot
DATABASE_URL=value

# VIP group ID for moderation (get this by adding bot to group and checking)
VIP_GROUP_ID=-100value

# Public base URL of this deployment, no trailing slash (e.g. your Render host).
# Used to build Stripe redirect URLs. Production MUST set this to the live host;
# local dev defaults to http://localhost:10000 if unset.
BASE_URL=https://your-service.onrender.com

# Stripe redirect targets. Optional — each defaults to BASE_URL + the path below
# if unset. Override only if you need a different host/path per target.
# PAYMENT_SUCCESS_URL=https://your-service.onrender.com/payment-success
# PAYMENT_CANCEL_URL=https://your-service.onrender.com/payment-cancel
# STRIPE_PORTAL_RETURN_URL=https://your-service.onrender.com/payment-success

# Default 172800 = 48 hours
VIP_SUBSCRIPTION_LAPSE_REMOVAL_DELAY_SECONDS=172800

# How often reconciliation runs (seconds, minimum 5 in code)
VIP_MEMBERSHIP_SYNC_INTERVAL_SECONDS=60
SUBSCRIPTION_PAST_DUE_GRACE_DAYS=3
# ===========================================================================
# Stripe configuration
# ===========================================================================
#
# Two independent switches:
#
#   MOCK_PAYMENT_ENABLED  true  = simulated payments, no Stripe call at all
#                         false = talk to real Stripe (TEST or LIVE per below)
#
#   STRIPE_LIVE_MODE      false = use the STRIPE_TEST_* keys (Stripe sandbox)
#                         true  = use the STRIPE_LIVE_* keys (real money)
#                         (unset defaults to LIVE so production stays safe)
#
# The webhook secret is selected to MATCH the active mode automatically.
# ---------------------------------------------------------------------------

# --- TEST MODE (Stripe sandbox) -------------------------------------------
STRIPE_TEST_SECRET_KEY=sk_test_xxx
STRIPE_TEST_PRICE_ID=price_test_xxx
STRIPE_TEST_WEBHOOK_SECRET=whsec_test_xxx

# --- LIVE MODE (real money) -----------------------------------------------
STRIPE_LIVE_SECRET_KEY=sk_live_xxx
STRIPE_LIVE_PRICE_ID=price_live_xxx
STRIPE_LIVE_WEBHOOK_SECRET=whsec_live_xxx

# --- Feature flags ---------------------------------------------------------
# Local dev: fake payments are on. Set MOCK_PAYMENT_ENABLED=false to exercise
# real Stripe, then STRIPE_LIVE_MODE picks TEST vs LIVE keys.
MOCK_PAYMENT_ENABLED=false
STRIPE_LIVE_MODE=false


RESEND_API_KEY=re_value

TELEGRAM_BOT_URL=https://t.me/value

# --- Branding --------------------------------------------------------------
BRAND_NAME=VIP Spain Community(or any other value you prefer)
EMAIL_FROM=value

BASE_URL=value